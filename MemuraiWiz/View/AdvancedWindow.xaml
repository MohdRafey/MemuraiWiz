<Window x:Class="MemuraiWiz.View.AdvancedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        Title="Advanced Configuration" Height="700" Width="550" 
        WindowStartupLocation="CenterOwner" Background="#F5F5F5">

  <Window.Resources>
    <CollectionViewSource x:Key="GroupedParameters" Source="{Binding AdvancedParameters}">
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription PropertyName="Section"/>
      </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
  </Window.Resources>

  <Grid Margin="15">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedParameters}}">
      <ItemsControl.Template>
        <ControlTemplate>
          <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <ItemsPresenter />
          </ScrollViewer>
        </ControlTemplate>
      </ItemsControl.Template>

      <ItemsControl.GroupStyle>
        <GroupStyle>
          <GroupStyle.ContainerStyle>
            <Style TargetType="{x:Type GroupItem}">
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type GroupItem}">
                    <StackPanel Margin="0,0,0,15">
                      <Border Background="#E0E0E0" Padding="8,4" CornerRadius="4" Margin="0,0,0,5">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#333"/>
                      </Border>
                      <ItemsPresenter />
                    </StackPanel>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </GroupStyle.ContainerStyle>
        </GroupStyle>
      </ItemsControl.GroupStyle>

      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Grid Margin="10,2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="180"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="35"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding Key}" VerticalAlignment="Center" FontSize="12"/>
            <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Padding="3"/>

            <ToggleButton x:Name="AdvInfoBtn" Grid.Column="2" Content="?" Width="22" Height="22" 
                                      Margin="5,0,0,0" Style="{StaticResource {x:Static ToolBar.ToggleButtonStyleKey}}"/>

            <Popup IsOpen="{Binding IsChecked, ElementName=AdvInfoBtn}" 
                               PlacementTarget="{Binding ElementName=AdvInfoBtn}"
                               Placement="Right" StaysOpen="False" AllowsTransparency="True">
              <Border Background="#333" CornerRadius="4" Padding="10" MaxWidth="300">
                <TextBlock Text="{Binding Description}" Foreground="White" TextWrapping="Wrap" FontSize="11"/>
              </Border>
            </Popup>
          </Grid>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Button Grid.Row="1" Content="Close" Click="CloseButton_Click" 
                Width="100" Height="30" HorizontalAlignment="Right" Margin="0,15,0,0"/>
  </Grid>
</Window>